{
  "permissions": {
    "allow": [
      "Bash(vv:*)",
      "Bash(vv-mute:*)",
      "WebSearch",
      "WebFetch",
      "Bash(gh api *)",
      "Bash(npm list *)",
      "Bash(npx tsc --noEmit*)",
      "Bash(which *)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(echo *)",
      "Bash(pwd*)",
      "Bash(env*)",
      "Bash(printenv*)",
      "Bash(du *)",
      "Bash(df*)",
      "Bash(uname*)",
      "Bash(date*)",
      "Bash(whoami)",
      "Bash(id*)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(jq *)",
      "Bash(git * status*)",
      "Bash(git * diff*)",
      "Bash(git * log*)",
      "Bash(pyenv *)",
      "Bash(python3 $HOME/.claude/*)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m pip *)",
      "Bash(mkdir -p *)",
      "Bash(npm install *)",
      "Bash(npm init *)",
      "Bash(npx tsc *)",
      "Bash(npx @t09tanaka/mcp-simple-voicevox*)",
      "Bash(claude-team:*)",
      "Bash(mgrep *)",
      "Bash(cd * && npm *)",
      "Bash(cd * && npx tsc *)",
      "Bash(cd * && git status*)",
      "Bash(cd * && git diff*)",
      "Bash(cd * && git log*)",
      "Bash(cd * && git add *)",
      "Bash(cd * && git commit *)",
      "Bash(node $HOME/.claude/*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(newfs*)",
      "Bash(diskutil eraseDisk*)",
      "Bash(diskutil reformat*)",
      "Bash(defaults write *)",
      "Bash(networksetup *)",
      "Bash(chmod -R 777*)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start-snapshot.sh",
            "statusMessage": "スナップショットを確認中..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-compact-save.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/risk-analyzer.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/scripts/statusline-ring.py"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "voiceEnabled": true,
  "mcpServers": {
    "voicevox": {
      "command": "npx",
      "args": [
        "@t09tanaka/mcp-simple-voicevox"
      ]
    }
  }
}
